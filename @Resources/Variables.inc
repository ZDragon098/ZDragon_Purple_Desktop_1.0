[Variables]

; ── CHUNG ──────────────────────────────────
FontFace=Work Sans SemiBold

; ── TIME / PLAYER ──────────────────────────
ScrollMouseIncrement=0.05
Format=I
Hidden=1
Hidden2=0
Player=WMP
Color1=0,0,0,150
Color2=210,168,199,255

; ── MUSIC WIDGET (Medium) ──────────────────
WidgetWidth=200
WidgetHeight=100
WidgetRadius=12
WidgetPadding=8

; Màu sắc Music widget
BackgroundColor=20,20,20
ForegroundColor=255,255,255
GrayColor=100,100,100,150

; Tên app nhạc mở khi double-click
MusicApp=["spotify"]

; Plugin nhạc
Plugin=MediaPlayer
PlayerName=Default
Language=en